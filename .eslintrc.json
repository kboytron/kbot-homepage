{
  "root": true,
  "extends": [
    "next",
    "plugin:sonarjs/recommended-legacy"
  ],
  "plugins": [
    "sonarjs"
  ],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "react/display-name": 0,
    "sonarjs/cognitive-complexity": [
      "warn",
      15
    ],
    "sonarjs/no-duplicate-string": [
      "warn",
      {
        "threshold": 5
      }
    ]
  }
}